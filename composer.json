{
    "name": "utdal/cayuse-connect",
    "description": "UT Dallas Cayuse integration tool",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Wun Chiou",
            "email": "wun@utdallas.edu"
        }
    ],
    "require": {
        "php": ">=8.3",
        "league/csv": "^9.8",
        "nesbot/carbon": "^2.62",
        "symfony/dotenv": "^7.4",
        "symfony/http-client": "^7.4",
        "symfony/http-foundation": "^7.4"
    },
        "require-dev": {
        "symfony/var-dumper": "^7.4"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
