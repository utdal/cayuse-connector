APP_ENV="dev" # dev, development, prod, production
APP_NAME="Our Institution"

# default Cayuse server environment (e.g. UAT or production)
CAYUSE_SERVER_ENVIRONMENT="UAT"

# production settings
CAYUSE_TENANT_ID=""
CAYUSE_AUTH_SERVER="https://signin.app.cayuse.com"
CAYUSE_API_SERVER="https://developer.app.cayuse.com"
CAYUSE_HR_CONNECT_SERVER="https://our-institution.app.cayuse.com"
CAYUSE_USERNAME="prod.api.user"
CAYUSE_PASSWORD=""

# UAT (staging) settings
UAT_CAYUSE_TENANT_ID=""
UAT_CAYUSE_AUTH_SERVER="https://signin.uat.cayuse.com"
UAT_CAYUSE_API_SERVER="https://developer.uat.cayuse.com"
UAT_CAYUSE_HR_CONNECT_SERVER="https://our-institution.uat.cayuse.com"
UAT_CAYUSE_USERNAME="uat.api.user"
UAT_CAYUSE_PASSWORD=""

# roles to list
CAYUSE_ROLES="IRB User, Cayuse IRB Link Viewer, Animal Oversight and Hazard Safety Researcher Staff Members, Cayuse IACUC Link Viewer"